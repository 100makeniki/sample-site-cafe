<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home | BLOOM COFFEE&TEA STAND</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400&family=Noto+Sans+JP:wght@300;400&family=Montserrat:wght@200;300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
:root{
  --gold:#B8976A;
  --purple:#4A3878;
  --dark:#2C2C2C;
  --text:#3A3A3A;
  --muted:#888;
  --bg:#F9F9F7;
  --dot:rgba(0,0,0,0.1);
}
body{
  font-family:'Noto Sans JP',sans-serif;
  font-weight:300;
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
}
.dot-bg{
  background-image:radial-gradient(circle,var(--dot) 1px,transparent 1px);
  background-size:30px 30px;
  background-color:var(--bg);
}

/* ─ NAV ─ */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  display:flex;align-items:center;justify-content:space-around;
  padding:1.1rem 2rem;
  background:rgba(249,249,247,0.92);
  backdrop-filter:blur(6px);
}
nav a{
  font-family:'Montserrat',sans-serif;
  font-size:0.72rem;font-weight:300;
  letter-spacing:0.18em;color:var(--gold);
  text-decoration:none;transition:color .3s;
}
nav a:hover{color:var(--purple);}

/* ─ HERO ─ */
.hero{
  position:relative;height:100vh;overflow:hidden;
}
.hero-photo{
  position:absolute;inset:0;
  background:url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1600&q=80') center/cover no-repeat;
  filter:blur(3px) brightness(1.05);
  transform:scale(1.05);
}
.hero-photo::after{
  content:'';position:absolute;inset:0;
  background:rgba(249,246,240,0.15);
}
.hero-card{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  width:280px;
  background:rgba(22,20,16,0.9);
  padding:2.8rem 2.2rem 2rem;
  text-align:center;z-index:2;
}
.hero-card-sub{
  font-family:'Montserrat',sans-serif;
  font-size:0.6rem;letter-spacing:0.4em;
  color:rgba(255,255,255,0.55);margin-bottom:1.4rem;
}
.hero-brand{
  font-family:'Montserrat',sans-serif;
  font-size:2.8rem;font-weight:200;
  letter-spacing:0.08em;color:#fff;
  line-height:1;margin:0.4rem 0 0.6rem;
  font-style:italic;
}
.hero-tagline{
  font-family:'Montserrat',sans-serif;
  font-size:0.55rem;letter-spacing:0.32em;
  color:rgba(255,255,255,0.6);
}
.hero-park{
  font-family:'Montserrat',sans-serif;
  font-size:0.48rem;letter-spacing:0.3em;
  color:rgba(255,255,255,0.35);margin-top:0.2rem;
}
.hero-addr{
  margin-top:1.4rem;padding-top:1rem;
  border-top:1px solid rgba(255,255,255,0.1);
  font-size:0.55rem;letter-spacing:0.12em;
  color:rgba(255,255,255,0.35);line-height:2.2;
}
.hero-social{
  position:absolute;bottom:2.5rem;left:50%;
  transform:translateX(-50%);
  display:flex;gap:0.8rem;z-index:2;
}
.social-btn{
  width:38px;height:38px;border-radius:50%;
  background:#111;display:flex;align-items:center;justify-content:center;
  text-decoration:none;color:#fff;
  font-size:0.9rem;font-weight:400;
  transition:background .3s;
}
.social-btn:hover{background:#333;}
.social-btn svg{width:18px;height:18px;fill:white;}

/* ─ NEWS ─ */
.news-sec{padding:5rem 0;}
.news-wrap{
  max-width:580px;margin:0 auto;
  text-align:center;padding:0 2rem;
}
.news-article{
  background:rgba(240,236,228,0.6);
  padding:3.5rem 3rem;
  position:relative;
}
.news-article::before{
  content:'';position:absolute;
  top:0;left:50%;transform:translateX(-50%);
  width:1px;height:30px;background:var(--gold);
  top:-30px;
}
.news-h{
  font-family:'Noto Serif JP',serif;
  font-size:1.05rem;font-weight:400;
  letter-spacing:0.2em;color:var(--dark);
  margin-bottom:1.8rem;
}
.news-body{
  font-family:'Noto Serif JP',serif;
  font-size:0.9rem;font-weight:300;
  line-height:2.6;color:var(--text);
  text-align:center;
}

/* ─ 2COL LAYOUT ─ */
.two-col{
  display:grid;
  grid-template-columns:1fr 1fr;
  align-items:center;
  max-width:1060px;
  margin:0 auto;
  padding:0 5rem;
  gap:5rem;
}
.two-col.rev{direction:rtl;}
.two-col.rev>*{direction:ltr;}

.col-img{width:100%;display:block;}
.col-img-wrap{
  overflow:hidden;
  line-height:0;
}
.col-img-wrap img{
  width:100%;
  aspect-ratio:3/4;
  object-fit:cover;
  display:block;
}
.col-img-placeholder{
  width:100%;aspect-ratio:3/4;
  background:#2A2726;
  display:flex;align-items:center;justify-content:center;
}
.col-img-placeholder-tea{
  width:100%;aspect-ratio:3/4;
  background:#E2DDD6;
  display:flex;align-items:center;justify-content:center;
}

.eyebrow{
  font-family:'Montserrat',sans-serif;
  font-size:0.62rem;letter-spacing:0.45em;
  color:var(--gold);margin-bottom:1rem;
}
.gold-arrow-wrap{
  display:flex;align-items:center;gap:0.5rem;
  margin-bottom:0.8rem;
}
.sec-heading{
  font-family:'Noto Serif JP',serif;
  font-size:1.9rem;font-weight:300;
  letter-spacing:0.22em;color:var(--purple);
  line-height:1.9;margin-bottom:1.8rem;
}
.gold-bar{
  width:55px;height:1px;
  background:var(--gold);margin-bottom:2rem;
}
.sec-body{
  font-family:'Noto Serif JP',serif;
  font-size:0.88rem;font-weight:300;
  line-height:2.8;color:var(--text);
  border-left:1px solid var(--gold);
  padding-left:1.4rem;
}

/* ─ LOCATION BANNER ─ */
.location-banner img,
.location-banner-ph{
  width:100%;
  aspect-ratio:16/5;
  object-fit:cover;display:block;
}
.location-banner-ph{
  background:linear-gradient(to right,#C0AFA0,#A89888);
}
.location-heading{
  text-align:left;
  padding:2.5rem 5rem 0.5rem;
  max-width:1060px;margin:0 auto;
}
.location-h{
  font-family:'Montserrat',sans-serif;
  font-size:2.2rem;font-weight:300;
  letter-spacing:0.25em;color:var(--purple);
}
.location-sub{
  font-family:'Montserrat',sans-serif;
  font-size:0.62rem;letter-spacing:0.4em;
  color:var(--gold);margin-top:0.3rem;
}

/* ─ PHOTO ROW (店内) ─ */
.photo-row{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:4px;
  max-width:1060px;
  margin:2rem auto 0;
  padding:0 5rem;
}
.photo-cell{
  aspect-ratio:1;overflow:hidden;
  background:#C8C0B4;
}
.photo-cell:nth-child(2){background:#D0C8BA;}
.photo-cell:nth-child(3){background:#BEB6A8;}
.photo-cell:nth-child(4){background:#C8C0B4;}

/* ─ WORKSHOP TWO-COL ─ */
.workshop-sec{padding:6rem 0;}

/* ─ INSTAGRAM EMBED ─ */
.insta-sec{
  padding:4rem 0 6rem;
  text-align:center;
}
.insta-label{
  font-family:'Montserrat',sans-serif;
  font-size:0.62rem;letter-spacing:0.45em;
  color:var(--gold);margin-bottom:2.5rem;
}
.insta-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:3px;
  max-width:880px;
  margin:0 auto;
  padding:0 4rem;
}
.insta-cell{
  aspect-ratio:1;
  background:#DDD8D0;
  overflow:hidden;
  position:relative;
  cursor:pointer;
}
.insta-cell:nth-child(2){background:#E0D8CE;}
.insta-cell:nth-child(3){background:#D8D0C6;}
.insta-cell:nth-child(4){background:#E4DCD2;}
.insta-cell::after{
  content:'';position:absolute;inset:0;
  background:rgba(0,0,0,0);
  transition:background .3s;
}
.insta-cell:hover::after{background:rgba(0,0,0,0.18);}
.insta-cell-inner{
  width:100%;height:100%;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:0.5rem;
}
.insta-icon{font-size:1.6rem;opacity:0.35;}
.insta-follow{
  margin-top:1.8rem;
  font-family:'Montserrat',sans-serif;
  font-size:0.62rem;letter-spacing:0.3em;
  color:var(--muted);
}
.insta-follow a{color:var(--gold);text-decoration:none;}

/* ─ CONTACT ─ */
.contact-sec{
  padding:6rem 0;
}
.contact-inner{
  display:grid;
  grid-template-columns:1fr 1fr;
  align-items:start;
  max-width:1060px;margin:0 auto;
  padding:0 5rem;gap:4rem;
}
.contact-h{
  font-family:'Montserrat',sans-serif;
  font-size:2rem;font-weight:300;
  letter-spacing:0.2em;color:var(--purple);
  margin-bottom:0.8rem;
}
.contact-bracket{
  font-family:'Noto Sans JP',sans-serif;
  font-size:0.75rem;letter-spacing:0.15em;
  color:var(--purple);margin-bottom:0.4rem;
}
.contact-time-label{
  font-family:'Noto Sans JP',sans-serif;
  font-size:0.8rem;letter-spacing:0.1em;
  color:var(--dark);margin-bottom:0.2rem;
}
.contact-time{
  font-size:0.88rem;letter-spacing:0.1em;
  color:var(--text);margin-bottom:1rem;
}
.contact-note{
  font-size:0.78rem;line-height:2.4;
  color:var(--text);
  border-left:3px solid var(--gold);
  padding-left:1rem;margin-bottom:1.5rem;
}
.contact-tel{
  font-family:'Montserrat',sans-serif;
  font-size:0.9rem;letter-spacing:0.1em;
  color:var(--gold);margin-bottom:0.5rem;
}
.contact-mail a{
  font-size:0.82rem;color:var(--gold);
  text-decoration:none;letter-spacing:0.05em;
}
.contact-address{
  font-size:0.8rem;line-height:2.4;
  color:var(--muted);margin-top:1rem;
}
.map-placeholder{
  width:100%;aspect-ratio:4/3;
  background:#E8EEE8;
  border:1px solid #D0D8D0;
  display:flex;align-items:center;justify-content:center;
  font-size:0.72rem;letter-spacing:0.2em;
  color:#888;position:relative;overflow:hidden;
}
.map-placeholder iframe{
  position:absolute;inset:0;width:100%;height:100%;border:0;
}

/* ─ FOOTER ─ */
footer{
  padding:2rem;text-align:center;
  border-top:1px solid rgba(0,0,0,0.06);
}
footer p{
  font-family:'Montserrat',sans-serif;
  font-size:0.55rem;letter-spacing:0.2em;color:#AAA;
}

/* ─ SECTION PADDING ─ */
.section{padding:7rem 0;}

/* ─ REVEAL ─ */
.reveal{opacity:0;transform:translateY(22px);transition:opacity .9s ease,transform .9s ease;}
.reveal.on{opacity:1;transform:none;}

@media(max-width:820px){
  .two-col,.contact-inner{grid-template-columns:1fr;padding:0 2rem;gap:3rem;}
  .two-col.rev{direction:ltr;}
  .photo-row,.insta-grid{grid-template-columns:1fr 1fr;padding:0 1.5rem;}
  .location-heading{padding:2rem 2rem 0.5rem;}
  nav{justify-content:space-evenly;padding:1rem;}
  nav a{font-size:0.65rem;letter-spacing:0.1em;}
}
</style>
</head>
